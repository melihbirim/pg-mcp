{
  "name": "postgresql-mcp",
  "displayName": "PostgreSQL MCP",
  "description": "PostgreSQL Model Context Protocol extension for natural language database queries",
  "version": "1.0.0",
  "publisher": "melihbirim",
  "repository": {
    "type": "git",
    "url": "https://github.com/melihbirim/pg-mcp"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Data Science"
  ],
  "keywords": [
    "postgresql",
    "database",
    "sql",
    "natural-language",
    "mcp",
    "ai"
  ],
  "activationEvents": [
    "onCommand:postgresql-mcp.connect",
    "onCommand:postgresql-mcp.disconnect",
    "onCommand:postgresql-mcp.query",
    "onCommand:postgresql-mcp.showSchema"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "postgresql-mcp.connect",
        "title": "Connect to PostgreSQL Database",
        "category": "PostgreSQL MCP",
        "icon": "$(database)"
      },
      {
        "command": "postgresql-mcp.disconnect",
        "title": "Disconnect from Database",
        "category": "PostgreSQL MCP",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "postgresql-mcp.query",
        "title": "Execute Natural Language Query",
        "category": "PostgreSQL MCP",
        "icon": "$(search)"
      },
      {
        "command": "postgresql-mcp.showSchema",
        "title": "Show Database Schema",
        "category": "PostgreSQL MCP",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "postgresql-mcp.listTables",
        "title": "List Tables",
        "category": "PostgreSQL MCP",
        "icon": "$(list-tree)"
      },
      {
        "command": "postgresql-mcp.describeTable",
        "title": "Describe Table",
        "category": "PostgreSQL MCP",
        "icon": "$(info)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "postgresql-mcp-explorer",
          "name": "PostgreSQL MCP",
          "when": "postgresql-mcp:connected"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "postgresql-mcp",
          "title": "PostgreSQL MCP",
          "icon": "$(database)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "postgresql-mcp.connect",
          "when": "view == postgresql-mcp-explorer && !postgresql-mcp:connected",
          "group": "navigation"
        },
        {
          "command": "postgresql-mcp.disconnect",
          "when": "view == postgresql-mcp-explorer && postgresql-mcp:connected",
          "group": "navigation"
        },
        {
          "command": "postgresql-mcp.query",
          "when": "view == postgresql-mcp-explorer && postgresql-mcp:connected",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "postgresql-mcp.disconnect",
          "when": "postgresql-mcp:connected"
        },
        {
          "command": "postgresql-mcp.query",
          "when": "postgresql-mcp:connected"
        },
        {
          "command": "postgresql-mcp.showSchema",
          "when": "postgresql-mcp:connected"
        },
        {
          "command": "postgresql-mcp.listTables",
          "when": "postgresql-mcp:connected"
        },
        {
          "command": "postgresql-mcp.describeTable",
          "when": "postgresql-mcp:connected"
        }
      ]
    },
    "configuration": {
      "title": "PostgreSQL MCP",
      "properties": {
        "postgresql-mcp.defaultHost": {
          "type": "string",
          "default": "localhost",
          "description": "Default PostgreSQL host"
        },
        "postgresql-mcp.defaultPort": {
          "type": "number",
          "default": 5432,
          "description": "Default PostgreSQL port"
        },
        "postgresql-mcp.defaultDatabase": {
          "type": "string",
          "default": "postgres",
          "description": "Default database name"
        },
        "postgresql-mcp.enableSsl": {
          "type": "boolean",
          "default": false,
          "description": "Enable SSL connection by default"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "@types/pg": "^8.15.4",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "typescript": "^4.9.4",
    "@vscode/vsce": "^2.15.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.16.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  }
}
